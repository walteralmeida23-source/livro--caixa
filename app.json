{
  "expo": {
    "name": "Livro de Caixa",
    "slug": "livro-caixa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1E8"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1E8"
      },
      "package": "com.hellenalves.livrocaixa",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite acesso às fotos para anexar faturas.",
          "cameraPermission": "Permite acesso à câmara para fotografar faturas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c7958245-0129-4a96-a4ce-99360382ad56"
      }
    }
  }
}
